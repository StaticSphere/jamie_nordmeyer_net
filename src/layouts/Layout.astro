---
import "../styles/global.css";

type Props = {
  pageTitle?: string;
  pageDescription?: string;
};

const {
  pageTitle = "JamieNordmeyer.net",
  pageDescription = "The various ramblings of a Portland code monkey"
} = Astro.props;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-site-bg font-sans text-site-text antialiased">
    <a
      class="fixed left-1/2 -top-10 z-50 -translate-x-1/2 bg-site-darker px-3 py-2 text-sm text-white transition-all focus:top-2"
      href="#primary-container"
    >
      Press "Enter" to skip to content
    </a>

    <div class="relative min-h-screen overflow-x-hidden">
      <header id="site-header" role="banner" class="bg-site-dark px-page-x pb-20 pt-9 text-center text-white md:text-left">
        <div class="mx-auto max-w-325">
          <div id="title-container" class="mb-6 md:float-left md:relative md:z-10 md:mb-9">
            <div id="site-title" class="heading-site">
              <a class="text-white transition-colors hover:text-site-light" href="/">JamieNordmeyer.net</a>
            </div>
            <p class="text-meta m-0 text-site-light md:inline-block">
              The various ramblings of a Portland code monkey
            </p>
          </div>
          <div class="mb-6 md:float-right md:mb-0">
            <ul class="mb-6 flex list-none items-center justify-center gap-5 p-0 md:mb-0 md:inline-flex">
              <li>
                <a class="text-white transition-colors hover:text-site-light" target="_blank" rel="noreferrer" href="https://www.linkedin.com/in/nordyj/" aria-label="LinkedIn">
                  <i class="fab fa-linkedin text-base" aria-hidden="true"></i>
                </a>
              </li>
              <li>
                <a class="text-white transition-colors hover:text-site-light" target="_blank" rel="noreferrer" href="https://github.com/StaticSphere" aria-label="GitHub">
                  <i class="fab fa-github text-base" aria-hidden="true"></i>
                </a>
              </li>
              <li>
                <a class="text-white transition-colors hover:text-site-light" target="_blank" rel="noreferrer" href="https://medium.com/@jamienordmeyer" aria-label="Medium">
                  <i class="fab fa-medium text-base" aria-hidden="true"></i>
                </a>
              </li>
            </ul>
          </div>

          <button
            id="toggle-navigation"
            class="my-6 text-white transition-colors hover:text-site-light md:hidden"
            name="toggle-navigation"
            aria-expanded="false"
          >
            <span class="sr-only">open menu</span>
            <svg width="36" height="23" viewBox="0 0 36 23" aria-hidden="true" focusable="false" class="fill-current">
              <rect x="0" y="20" width="36" height="3"></rect>
              <rect x="0" y="10" width="36" height="3"></rect>
              <rect x="0" y="0" width="36" height="3"></rect>
            </svg>
          </button>

          <div id="menu-primary-container" class="hidden clear-both md:block">
            <nav
              id="menu-primary"
              role="navigation"
              aria-label="Primary Navigation"
              class="my-6 text-nav md:mt-6"
            >
              <ul class="m-0 list-none p-0">
                <li class="mb-1.5 md:mr-2 md:mb-0 md:inline-block">
                  <a
                    class="inline-block px-2 first:pl-0 last:pl-0 pb-0.5 text-white transition-colors  hover:font-bold"
                    href="/about-me/"
                  >
                    About Me
                  </a>
                </li>
              </ul>
            </nav>
          </div>
        </div>
      </header>

      <div id="primary-container" class="layout-primary px-page-x">
        <slot />
      </div>
    </div>

    <script is:inline>
      const toggleButton = document.getElementById("toggle-navigation");
      const menuContainer = document.getElementById("menu-primary-container");
      const searchButton = document.getElementById("search-icon");
      const searchForm = document.getElementById("search-form");

      if (toggleButton && menuContainer) {
        toggleButton.addEventListener("click", () => {
          const isHidden = menuContainer.classList.toggle("hidden");
          toggleButton.setAttribute("aria-expanded", String(!isHidden));
        });
      }

      if (searchButton && searchForm) {
        searchButton.addEventListener("click", () => {
          const isHidden = searchForm.classList.toggle("hidden");
          searchButton.setAttribute("aria-expanded", String(!isHidden));
        });
      }
    </script>
  </body>
</html>

