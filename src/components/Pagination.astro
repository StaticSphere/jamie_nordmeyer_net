---
type Props = {
  currentPage: number;
  totalPages: number;
};

const { currentPage, totalPages } = Astro.props;

if (totalPages <= 1) {
  return null;
}

const getPageHref = (page: number) => (page === 1 ? "/" : `/page/${page}/`);

const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);

const visiblePages = pageNumbers.filter((page) => {
  if (totalPages <= 5) {
    return true;
  }

  return page === 1 || page === totalPages || Math.abs(page - currentPage) <= 1;
});

const pagesWithGaps: Array<number | "dots"> = [];

for (const page of visiblePages) {
  const previous = pagesWithGaps[pagesWithGaps.length - 1];

  if (typeof previous === "number" && page - previous > 1) {
    pagesWithGaps.push("dots");
  }

  pagesWithGaps.push(page);
}
---

<nav aria-label="Posts" class="mb-6 bg-white px-content-x py-6 text-center shadow-card sm:relative">
  <h2 class="sr-only">Posts navigation</h2>
  <div class="flex flex-wrap items-center justify-center gap-y-3">
    {currentPage > 1 && (
      <a class="mr-3 text-center font-bold transition-colors hover:text-site-muted sm:absolute sm:left-content-x" href={getPageHref(currentPage - 1)}>
        Previous
      </a>
    )}

    {pagesWithGaps.map((entry) =>
      entry === "dots" ? (
        <span class="mx-3 inline-block">&hellip;</span>
      ) : entry === currentPage ? (
        <span aria-current="page" class="mx-3 inline-block bg-site-bg px-2 py-0.5">{entry}</span>
      ) : (
        <a class="mx-3 inline-block transition-colors hover:text-site-muted" href={getPageHref(entry)}>{entry}</a>
      )
    )}

    {currentPage < totalPages && (
      <a class="ml-3 text-center font-bold transition-colors hover:text-site-muted sm:absolute sm:right-content-x" href={getPageHref(currentPage + 1)}>
        Next
      </a>
    )}
  </div>
</nav>
