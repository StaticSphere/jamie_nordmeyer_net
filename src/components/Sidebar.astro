---
import type { PostEntry, Taxonomy } from "../lib/content";
import { getCategoryUrl, getPostUrl, getTagUrl } from "../lib/content";

type Props = {
  recentPosts: PostEntry[];
  categories: Taxonomy[];
  tags: Taxonomy[];
};

const { recentPosts, categories, tags } = Astro.props;

const maxTagCount = tags.reduce((max, tag) => Math.max(max, tag.count), 1);

const getTagSize = (count: number) => {
  const min = 8;
  const max = 20;
  const ratio = count / maxTagCount;
  return `${Math.round(min + ratio * (max - min))}pt`;
};
---

<aside id="sidebar-primary" role="complementary" class="mt-12 md:flex-1">
  <h2 class="sr-only">Sidebar</h2>

  <section class="surface-card surface-body mb-3 md:pt-7.5">
    <h3 class="mb-6 text-base leading-normal font-bold">Recent Posts</h3>
    <ul class="m-0 list-disc pl-5 text-nav">
      {recentPosts.map((post) => (
        <li class="mb-1.5 last:mb-0"><a class="transition-colors hover:underline" href={getPostUrl(post)}>{post.data.title}</a></li>
      ))}
    </ul>
  </section>

  <section class="surface-card surface-body mb-3 md:pt-7.5">
    <h3 class="mb-6 text-base leading-normal font-bold">Categories</h3>
    <ul class="m-0 list-disc pl-5 text-nav">
      {categories.map((category) => (
        <li class="mb-1.5 last:mb-0"><a class="transition-colors hover:underline" href={getCategoryUrl(category.slug)}>{category.name}</a></li>
      ))}
    </ul>
  </section>

  <section class="surface-card surface-body md:pt-7.5">
    <h3 class="mb-6 text-base leading-normal font-bold">Tags</h3>
    <div class="flex flex-wrap gap-x-2 gap-y-1 text-sm leading-snug">
      {tags.map((tag) => (
        <a class="inline-block transition-colors hover:underline" href={getTagUrl(tag.slug)} style={`font-size: ${getTagSize(tag.count)};`}>{tag.name}</a>
      ))}
    </div>
  </section>
</aside>
