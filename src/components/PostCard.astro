---
import type { PostEntry } from "../lib/content";
import { getPostUrl } from "../lib/content";

type Props = {
  post: PostEntry;
  showExcerpt?: boolean;
};

const { post, showExcerpt = true } = Astro.props;
const publishedDate = post.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});
const postUrl = getPostUrl(post);
---

<div class="relative mb-6">
  <article class="surface-card">
    {post.data.featuredImage && (
      <div class="media-frame">
        <a href={postUrl} aria-label={post.data.title} class="absolute inset-0 block">
          <img
            src={post.data.featuredImage}
            alt={post.data.featuredImageAlt ?? ""}
            loading="lazy"
            class="media-fill"
          />
        </a>
      </div>
    )}

    <div class="surface-body mb-3">
      <header class="mb-6">
        <h2 class="heading-page">
          <a class="transition-colors hover:text-site-muted" href={postUrl}>{post.data.title}</a>
        </h2>
        <div class="text-xs leading-normal">Published {publishedDate} by {post.data.author}</div>
      </header>

      {showExcerpt ? (
        <div class="content-prose">
          <p class="my-6">{post.data.excerpt}</p>
          <div class="inline-block">
            <a
              class="inline-block border border-site-text px-3 py-1.5 text-nav transition-colors hover:bg-site-text hover:text-white"
              href={postUrl}
            >
              Continue reading
            </a>
          </div>
        </div>
      ) : null}
    </div>
  </article>
</div>
