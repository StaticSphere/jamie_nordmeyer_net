---
import Pagination from '../components/Pagination.astro';
import PostCard from '../components/PostCard.astro';
import Sidebar from '../components/Sidebar.astro';
import Layout from '../layouts/Layout.astro';
import { getAllCategories, getAllTags, getPaginatedPosts, getRecentPosts } from '../lib/content';

const { posts, currentPage, totalPages } = await getPaginatedPosts(1);
const recentPosts = await getRecentPosts(5);
const categories = await getAllCategories();
const tags = await getAllTags();
---

<Layout pageTitle="JamieNordmeyer.net" pageDescription="The various ramblings of a Portland code monkey">
  <div class="layout-shell">
    <section id="main" role="main" class="layout-main">
      <h1 class="sr-only">JamieNordmeyer.net Posts</h1>
      <div id="loop-container">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
      <Pagination currentPage={currentPage} totalPages={totalPages} />
    </section>

    <Sidebar recentPosts={recentPosts} categories={categories} tags={tags} />
  </div>
</Layout>
