---
import Pagination from "../../components/Pagination.astro";
import PostCard from "../../components/PostCard.astro";
import Sidebar from "../../components/Sidebar.astro";
import Layout from "../../layouts/Layout.astro";
import {
  getAllCategories,
  getAllTags,
  getPaginatedPosts,
  getRecentPosts,
  getTotalPostPages
} from "../../lib/content";

export async function getStaticPaths() {
  const totalPages = await getTotalPostPages();

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => ({
    params: { page: String(index + 2) }
  }));
}

const pageParam = Number(Astro.params.page);

if (!Number.isInteger(pageParam) || pageParam < 2) {
  throw new Error(`Invalid paginated route: ${Astro.params.page}`);
}

const { posts, currentPage, totalPages } = await getPaginatedPosts(pageParam);
const recentPosts = await getRecentPosts(5);
const categories = await getAllCategories();
const tags = await getAllTags();
---

<Layout
  pageTitle={`JamieNordmeyer.net - Page ${currentPage}`}
  pageDescription="The various ramblings of a Portland code monkey"
>
  <div class="max-width">
    <section id="main" class="main" role="main">
      <h1 class="screen-reader-text">JamieNordmeyer.net Posts - Page {currentPage}</h1>
      <div id="loop-container" class="loop-container">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
      <Pagination currentPage={currentPage} totalPages={totalPages} />
    </section>

    <Sidebar recentPosts={recentPosts} categories={categories} tags={tags} />
  </div>
</Layout>

