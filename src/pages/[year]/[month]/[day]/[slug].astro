---
import { Image } from "astro:assets";
import { render } from "astro:content";
import Layout from "../../../../layouts/Layout.astro";
import Sidebar from "../../../../components/Sidebar.astro";
import {
  getAllCategories,
  getAllPosts,
  getAllTags,
  getCategoryUrl,
  getEntrySlug,
  getPostByDateAndSlug,
  getRecentPosts,
  getTagUrl
} from "../../../../lib/content";

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return posts.map((post) => {
    const year = String(post.data.date.getFullYear());
    const month = String(post.data.date.getMonth() + 1).padStart(2, "0");
    const day = String(post.data.date.getDate()).padStart(2, "0");

    return {
      params: {
        year,
        month,
        day,
        slug: getEntrySlug(post)
      }
    };
  });
}

const slug = Astro.params.slug;
const year = Astro.params.year;
const month = Astro.params.month;
const day = Astro.params.day;

const post =
  slug && year && month && day ? await getPostByDateAndSlug(year, month, day, slug) : undefined;

if (!post) {
  throw new Error(`Post not found for route params: ${year}/${month}/${day}/${slug}`);
}

const { Content } = await render(post);
const recentPosts = await getRecentPosts(5);
const categories = await getAllCategories();
const tags = await getAllTags();
const publishedDate = post.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});
const categoryTerms = post.data.categories;
const tagTerms = post.data.tags;
---

<Layout pageTitle={`JamieNordmeyer.net - ${post.data.title}`}>
  <div class="layout-shell">
    <main id="main" role="main" class="layout-main">
      <article class="relative mb-6">
        <div class="surface-card">
          {post.data.featuredImage && (
            <div class="media-frame">
              <Image src={post.data.featuredImage} alt={post.data.featuredImageAlt ?? ""} class="media-fill" />
            </div>
          )}

          <div class="surface-body mb-3">
            <header class="mb-6">
              <h1 class="heading-page">{post.data.title}</h1>
              <div class="text-xs leading-normal">Published {publishedDate} by {post.data.author}</div>
            </header>

            <div class="content-prose prose prose-neutral max-w-none prose-a:font-bold prose-a:underline prose-a:text-site-text">
              <Content />
            </div>

            <footer class="mt-6">
              {categoryTerms.length > 0 && (
                <p class="mb-4">
                  Categories: {categoryTerms.map((category: (typeof categoryTerms)[number], index: number) => (
                    <>
                      {index > 0 ? ", " : ""}
                      <a class="font-bold transition-colors hover:text-site-muted" href={getCategoryUrl(category.slug)}>{category.name}</a>
                    </>
                  ))}
                </p>
              )}
              {tagTerms.length > 0 && (
                <p class="mb-4">
                  Tags: {tagTerms.map((tag: (typeof tagTerms)[number], index: number) => (
                    <>
                      {index > 0 ? ", " : ""}
                      <a class="font-bold transition-colors hover:text-site-muted" href={getTagUrl(tag.slug)}>{tag.name}</a>
                    </>
                  ))}
                </p>
              )}
            </footer>
          </div>
        </div>
      </article>
    </main>

    <Sidebar recentPosts={recentPosts} categories={categories} tags={tags} />
  </div>
</Layout>

