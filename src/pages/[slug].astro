---
import { render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import {
  getAllCategories,
  getAllPages,
  getAllTags,
  getEntrySlug,
  getPageBySlug,
  getRecentPosts
} from "../lib/content";

export async function getStaticPaths() {
  const pages = await getAllPages();
  return pages.map((page) => ({ params: { slug: getEntrySlug(page) } }));
}

const slug = Astro.params.slug;
const page = slug ? await getPageBySlug(slug) : undefined;

if (!page) {
  throw new Error(`Page not found for slug: ${slug}`);
}

const { Content } = await render(page);
const recentPosts = await getRecentPosts(5);
const categories = await getAllCategories();
const tags = await getAllTags();
---

<Layout pageTitle={`JamieNordmeyer.net - ${page.data.title}`}>
  <div class="max-width">
    <main id="main" class="main" role="main">
      <article class="entry">
        <div class="post-container post-container-single">
          <header class="post-header">
            <h1 class="post-title">{page.data.title}</h1>
          </header>

          <div class="post-content">
            <Content />
          </div>
        </div>
      </article>
    </main>

    <Sidebar recentPosts={recentPosts} categories={categories} tags={tags} />
  </div>
</Layout>


