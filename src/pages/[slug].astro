---
import { render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import {
  getAllCategories,
  getAllPages,
  getAllTags,
  getEntrySlug,
  getPageBySlug,
  getRecentPosts
} from "../lib/content";

export async function getStaticPaths() {
  const pages = await getAllPages();
  return pages.map((page) => ({ params: { slug: getEntrySlug(page) } }));
}

const slug = Astro.params.slug;
const page = slug ? await getPageBySlug(slug) : undefined;

if (!page) {
  throw new Error(`Page not found for slug: ${slug}`);
}

const { Content } = await render(page);
const recentPosts = await getRecentPosts(5);
const categories = await getAllCategories();
const tags = await getAllTags();
---

<Layout pageTitle={`JamieNordmeyer.net - ${page.data.title}`}>
  <div class="layout-shell">
    <main id="main" role="main" class="layout-main">
      <article class="relative mb-6">
        <div class="surface-card surface-body mb-3">
          <header class="mb-6">
            <h1 class="heading-page">{page.data.title}</h1>
          </header>

          <div class="content-prose prose prose-neutral max-w-none prose-a:font-bold prose-a:underline prose-a:text-site-text">
            <Content />
          </div>
        </div>
      </article>
    </main>

    <Sidebar recentPosts={recentPosts} categories={categories} tags={tags} />
  </div>
</Layout>
